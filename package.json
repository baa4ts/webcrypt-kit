{
  "name": "webcrypt-kit",
  "version": "1.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rslib",
    "dev": "rslib --watch",
    "format": "prettier --write .",
    "lint": "rslint",
    "test": "rstest",
    "test:watch": "rstest --watch"
  },
  "devDependencies": {
    "@rslib/core": "^0.23.2",
    "@rslint/core": "^0.5.3",
    "@rstest/adapter-rslib": "^0.10.6",
    "@rstest/core": "^0.10.6",
    "@types/node": "^24.13.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/baa4ts/webcrypt-kit.git"
  }
}